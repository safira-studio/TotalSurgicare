NEXT_PUBLIC_APP_URL=

# Set to false to block “Undo settlement” on /prescription/settlements (service role API still wins).
SETTLEMENT_REOPEN_ALLOWED=

# --- AssemblyAI (voice-to-prescription transcription) ---
ASSEMBLYAI_API_KEY=
